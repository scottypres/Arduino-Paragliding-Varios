	(text "SparkFun Thing Plus and SparkFun Qwiic OLED replace the Feather/FeatherWing. OLED uses direct 3V3/GND/SDA/SCL pads; no PCB Qwiic port is placed."
		(at 18 18 0)
		(uuid 34d62a90-5c08-458b-b766-8d80d6849605)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
	)
	(text "SparkFun Thing Plus pinout and module outline are from SparkFun Eagle hardware. Onboard microSD exists; J3 is optional external SPI SD using GPIO2 as CS."
		(at 18 24 0)
		(uuid ccb78e3b-83db-4f70-a69d-aa2cd71706a7)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
	)
	(text "Ant Display tactile switch pad geometry and button net names are copied; UP net is routed to Thing FREEBIE/ESP4 to keep SDA free for I2C."
		(at 18 30 0)
		(uuid 1d59b588-6136-4267-9acb-34748d50c708)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
	)
	(text "HGLRC M100 footprint uses manual pad order RX TX VCC GND; VCC is tied to 3V3 per HGLRC 3.3V-5V product spec."
		(at 18 36 0)
		(uuid 0d07d82b-a252-4cac-b63e-431443e1f13d)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
	)
	(text "Buzzer circuit and copied original Buzzer PCB passives/JST/slide-switch footprints are preserved; PCB remains placement-only with no traces."
		(at 18 42 0)
		(uuid f071e086-a2ad-4490-9dfa-40edcb67ba34)
		(effects
			(font
				(size 1 1)
			)
			(justify left bottom)
		)
	)
