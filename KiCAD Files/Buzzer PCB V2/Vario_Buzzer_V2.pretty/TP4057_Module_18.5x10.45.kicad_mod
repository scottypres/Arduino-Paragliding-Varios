(footprint "TP4057_Module_18.5x10.45" (layer "F.Cu")
	(descr "HiLetGo TP4057 LiPo/LiIon charger. 18.5x10.45mm, 6 pads (IN+-, OUT+-, BAT+-). Built from DXF/PDF. Pads 1=BAT+ 2=BAT- netted; IN/OUT exposed unconnected.")
	(property "Reference" "REF**" (at 0 0 0) (layer "F.SilkS") (effects (font (size 1 1))))
	(property "Value" "TP4057_Module_18.5x10.45" (at 0 0 0) (layer "F.Fab") (hide yes) (effects (font (size 1 1))))
	(attr through_hole)
	(fp_line (start -9.25 -6.15) (end 9.25 -6.15) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 9.25 -6.15) (end 9.25 6.15) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 9.25 6.15) (end -9.25 6.15) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start -9.25 6.15) (end -9.25 -6.15) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_text user "TP4057" (at 0 -5.4 0) (layer "F.SilkS") (effects (font (size 0.7 0.7) (thickness 0.12))))
	(fp_text user "IN-      IN+" (at 0 -3.2 0) (layer "F.SilkS") (effects (font (size 0.5 0.5) (thickness 0.12))))
	(fp_text user "OUT- BAT- BAT+ OUT+" (at 0 5.6 0) (layer "F.SilkS") (effects (font (size 0.5 0.5) (thickness 0.12))))
	(pad "1" thru_hole rect (at 2.684 4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "BAT+") (pintype "passive"))
	(pad "2" thru_hole circle (at -2.684 4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "BAT-") (pintype "passive"))
	(pad "3" thru_hole circle (at -5.224 -4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "IN-") (pintype "passive"))
	(pad "4" thru_hole circle (at 5.224 -4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "IN+") (pintype "passive"))
	(pad "5" thru_hole circle (at -5.224 4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "OUT-") (pintype "passive"))
	(pad "6" thru_hole circle (at 5.224 4.500) (size 1.6 1.6) (drill 0.9) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "OUT+") (pintype "passive"))
	(model "${KIPRJMOD}/../Component References/HiLetGo TP4057 LiPo_LiIon Charger.step"
