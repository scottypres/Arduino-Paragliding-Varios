(footprint "Comidox_5V_Booster_10.75x10.75_3Pin" (layer "F.Cu")
	(descr "Comidox 5V booster board. 10.75x10.75mm, 3-pin 2.54mm (Vin/GND/Vout), pot dia5.25. Built from DXF/PDF.")
	(property "Reference" "REF**" (at 0 0 0) (layer "F.SilkS") (effects (font (size 1 1))))
	(property "Value" "Comidox_5V_Booster_10.75x10.75_3Pin" (at 0 0 0) (layer "F.Fab") (hide yes) (effects (font (size 1 1))))
	(attr through_hole)
	(fp_line (start -5.375 -5.375) (end 5.375 -5.375) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 5.375 -5.375) (end 5.375 5.375) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 5.375 5.375) (end -5.375 5.375) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start -5.375 5.375) (end -5.375 -5.375) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_circle (center 0 -1.5) (end 2.625 -1.5) (stroke (width 0.12) (type solid)) (fill no) (layer "F.SilkS"))
	(fp_text user "5V BOOST" (at 0 -4.6 0) (layer "F.SilkS") (effects (font (size 0.6 0.6) (thickness 0.12))))
	(fp_text user "Vin GND Vout" (at 0 4.7 0) (layer "F.SilkS") (effects (font (size 0.55 0.55) (thickness 0.12))))
	(pad "1" thru_hole rect (at -2.540 3.500) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "Vin") (pintype "passive"))
	(pad "2" thru_hole circle (at 0.000 3.500) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "GND") (pintype "passive"))
	(pad "3" thru_hole circle (at 2.540 3.500) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "Vout") (pintype "passive"))
	(model "${KIPRJMOD}/../Component References/Comidox 5V Booster Board.step"
		(offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
	(embedded_fonts no)
)
