(footprint "OLED_M16968_59x35_9Pin" (layer "F.Cu")
	(descr "M16968 OLED + rotary knob module. 59.3x35.3mm, 9-pin 2.54mm header, 4x M3.25 mounts. Built from DXF/PDF. pin1=3v3..pin9=CONFIRM.")
	(property "Reference" "REF**" (at 0 0 0) (layer "F.SilkS") (effects (font (size 1 1))))
	(property "Value" "OLED_M16968_59x35_9Pin" (at 0 0 0) (layer "F.Fab") (hide yes) (effects (font (size 1 1))))
	(attr through_hole)
	(fp_line (start -29.65 -17.65) (end 29.65 -17.65) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 29.65 -17.65) (end 29.65 17.65) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start 29.65 17.65) (end -29.65 17.65) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_line (start -29.65 17.65) (end -29.65 -17.65) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
	(fp_text user "M16968 OLED + KNOB" (at 0 -16.6 0) (layer "F.SilkS") (effects (font (size 0.8 0.8) (thickness 0.12))))
	(pad "1" thru_hole rect (at 20.950 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "3v3") (pintype "passive"))
	(pad "2" thru_hole circle (at 18.410 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "GND") (pintype "passive"))
	(pad "3" thru_hole circle (at 15.870 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "BACK") (pintype "passive"))
	(pad "4" thru_hole circle (at 13.330 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "ENC_B") (pintype "passive"))
	(pad "5" thru_hole circle (at 10.790 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "ENC_A") (pintype "passive"))
	(pad "6" thru_hole circle (at 8.250 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "ENC_PUSH") (pintype "passive"))
	(pad "7" thru_hole circle (at 5.710 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "OLED_SCL") (pintype "passive"))
	(pad "8" thru_hole circle (at 3.170 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "OLED_SDA") (pintype "passive"))
	(pad "9" thru_hole circle (at 0.630 -15.640) (size 1.8 1.8) (drill 1.0) (layers "*.Cu" "*.Mask") (remove_unused_layers no) (pinfunction "CONFIRM") (pintype "passive"))
	(pad "" np_thru_hole circle (at -29.500 -14.750) (size 3.25 3.25) (drill 3.25) (layers "*.Cu" "*.Mask"))
	(pad "" np_thru_hole circle (at 29.500 -14.750) (size 3.25 3.25) (drill 3.25) (layers "*.Cu" "*.Mask"))
	(pad "" np_thru_hole circle (at -29.650 14.750) (size 3.25 3.25) (drill 3.25) (layers "*.Cu" "*.Mask"))
	(pad "" np_thru_hole circle (at 29.650 14.750) (size 3.25 3.25) (drill 3.25) (layers "*.Cu" "*.Mask"))
	(fp_text user "pin1=3v3 ... pin9=CONFIRM" (at 0 16.6 0) (layer "F.SilkS") (effects (font (size 0.6 0.6) (thickness 0.12))))
	(model "${KIPRJMOD}/../Component References/M16968 OLED and Rotary Knob.step"
		(offset (xyz 0 0 0)) (scale (xyz 1 1 1)) (rotate (xyz 0 0 0)))
	(embedded_fonts no)
)
